generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum AppointmentStatus {
  pending
  confirmed
  canceled
  completed
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  role     UserRole

  client Client?
  barber Barber?
}

model Client {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  name      String
  phone     String
  address   String?
  cpf       Int?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  appointments Appointment[]
  sales        Sale[]
}

model Barber {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  name      String
  phone     String
  cpf       Int?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  appointments Appointment[]
  sales        Sale[]
}

model Product {
  id    Int    @id @default(autoincrement())
  name  String
  price Float
  stock Int
  sales Sale[]
}

model Appointment {
  id       Int               @id @default(autoincrement())
  date     DateTime
  status   AppointmentStatus @default(pending)
  clientId Int
  barberId Int

  client Client @relation(fields: [clientId], references: [id])
  barber Barber @relation(fields: [barberId], references: [id])
}

model Sale {
  id        Int      @id @default(autoincrement())
  clientId  Int
  barberId  Int
  productId Int
  quantity  Int
  total     Float    @default(0)
  createdAt DateTime @default(now())

  client  Client  @relation(fields: [clientId], references: [id])
  barber  Barber  @relation(fields: [barberId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}
